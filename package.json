{
  "name": "react-leaflet-geoman-v2",
  "version": "1.1.1",
  "description": "React wrapper for the leaflet-geoman plugin",
  "repository": "https://github.com/TurtIeSocks/react-leaflet-geoman",
  "author": "TurtIeSocks <58572875+TurtIeSocks@users.noreply.github.com>",
  "license": "MIT",
  "private": false,
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "vite",
    "build": "vite build && tsc --project tsconfig.build.json",
    "build:lib": "vite build",
    "build:ts": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "geojson": "^0.5.0",
    "jsdom": "^29.1.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-checker": "^0.13.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@geoman-io/leaflet-geoman-free": "^2",
    "leaflet": "^1",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-leaflet": "^4 || ^5"
  }
}
