{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "es2020",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "exclude": ["dist", "node_modules"],
  "include": ["src", "test"]
}
